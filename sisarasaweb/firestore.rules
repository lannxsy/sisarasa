rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────────────
    // Cek apakah user adalah mitra toko (ada dokumen stores/{uid}-nya)
    function isMitra(uid) {
      return exists(/databases/$(database)/documents/stores/$(uid));
    }

    // Cek apakah user adalah admin platform (ada dokumen admins/{uid}-nya).
    // Dipakai buat ngasih akses CRUD lintas-toko ke admin (Kelola Toko,
    // Kelola Admin), yang gak dibuka buat mitra biasa.
    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid));
    }

    // Cek apakah user adalah pemilik toko tertentu
    function isStoreOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── ADMINS ─────────────────────────────────────────────────────
    // admins/{uid} — penanda "user ini admin platform". TIDAK ADA
    // pendaftaran lewat aplikasi sama sekali — dokumennya cuma dibuat
    // manual lewat Firebase Console. Makanya di sini SENGAJA tidak ada
    // allow create/update/delete apapun (default: ditolak semua).
    match /admins/{uid} {
      // Baca: boleh baca dokumen admin milik SENDIRI (buat admin-guard.js
      // ngecek status login), ATAU kalau yang minta udah kebukti admin,
      // boleh baca SEMUA dokumen admins (buat halaman Kelola Admin nampilin
      // daftar semua admin).
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin(request.auth.uid));

      // Create/update/delete: HANYA admin yang sudah terdaftar yang boleh
      // nambah/hapus admin lain. Tetap gak ada jalur pendaftaran admin
      // pertama lewat aplikasi — admin PERTAMA selalu dibuat manual lewat
      // Firebase Console, baru admin itu bisa nambah admin berikutnya
      // lewat halaman Kelola Admin.
      allow create, update, delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ─── STORES ─────────────────────────────────────────────────────
    // stores/{uid} — dokumen profil toko milik mitra
    match /stores/{uid} {
      // Pembeli di mobile perlu baca info toko (nama, lokasi, isActive, dll)
      allow read: if request.auth != null;

      // Hanya bisa create untuk uid sendiri (saat register lewat web)
      allow create: if isStoreOwner(uid);

      // Hanya pemilik toko yang boleh update/delete tokonya sendiri.
      // Admin platform juga boleh (Kelola Toko: aktifkan/nonaktifkan/hapus
      // toko manapun).
      allow update, delete: if isStoreOwner(uid) || isAdmin(request.auth.uid);

      // Pembeli (siapapun yang login) boleh update HANYA field agregat
      // rating (`ratingAvg`, `ratingCount`), dipicu bareng runTransaction()
      // pas submit review baru (lihat rule `reviews` di bawah) — supaya
      // card toko di list bisa langsung nampilin rata-rata rating tanpa
      // query semua dokumen reviews tiap buka list. Field toko lainnya
      // (nama, alamat, dst) tetap terkunci — cuma mitra yang boleh ubah itu.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratingAvg', 'ratingCount'])
                    && request.resource.data.ratingCount is int
                    && request.resource.data.ratingCount >= 0
                    && request.resource.data.ratingAvg is number
                    && request.resource.data.ratingAvg >= 0
                    && request.resource.data.ratingAvg <= 5;

      // ─── MENUS (subkoleksi) ──────────────────────────────────────
      // stores/{uid}/menus/{menuId}
      match /menus/{menuId} {
        // Pembeli di mobile perlu baca menu toko
        allow read: if request.auth != null;

        // Mitra pemilik toko ini boleh kelola apapun di menunya.
        allow create, delete: if isStoreOwner(uid);
        allow update: if isStoreOwner(uid);

        // Pembeli (siapapun yang login) boleh update HANYA field `stock`,
        // dipakai saat checkout buat motong stok di sini juga (biar
        // Kelola Menu di web ikut sinkron sama magic_bags.stok). Field
        // lain (nama, harga, dst) tetap terkunci — cuma mitra yang boleh.
        allow update: if request.auth != null
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
                      && request.resource.data.stock is int
                      && request.resource.data.stock >= 0
                      && request.resource.data.stock <= resource.data.stock;
      }
    }

    // ─── ORDERS ─────────────────────────────────────────────────────
    // orders/{orderId}
    match /orders/{orderId} {
      // Semua user login bisa baca (mitra & pembeli; disederhanakan utk UAS
      // karena order lama tidak selalu punya field storeId)
      allow read: if request.auth != null;

      // Halaman pickup (dibuka tanpa login, hasil scan QR fisik) perlu
      // cek 1 order spesifik. TIDAK bisa dibuka untuk `list` tanpa syarat
      // (itu bakal expose semua order ke publik) — jadi pickup.html WAJIB
      // baca pakai getDoc(doc(db,'orders', orderId)) by document ID, bukan
      // query where(). orderId didapat dari URL (?oid=...), bukan ditebak.
      allow get: if true;

      // Hanya pembeli yang bisa buat order (dari mobile)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // Update status oleh siapapun yang login (mitra konfirmasi/tolak,
      // pembeli bisa lihat status)
      allow update: if request.auth != null;

      // Pickup via scan QR pakai kamera HP BIASA (bukan dari app) — jadi
      // TANPA LOGIN sama sekali, karena browser yang kebuka dari hasil
      // scan itu gak punya sesi Firebase Auth apapun. Makanya ini sengaja
      // dibuka untuk unauthenticated request, tapi dibatasi ketat:
      // - HANYA boleh ubah field `status`, field lain (harga, userId, dst)
      //   tetap terkunci.
      // - HANYA boleh jadi 'completed'.
      // - Status sebelumnya harus 'confirmed', biar pesanan yang masih
      //   'pending' (belum dikonfirmasi admin) atau yang sudah 'cancelled'
      //   gak bisa diubah lewat jalur ini.
      // Keamanannya bertumpu pada kodePickup yang acak & cuma dikasih
      // tau lewat QR fisik di layar pembeli — mirip nomor antrian kertas.
      allow update: if resource.data.status == 'confirmed'
                    && request.resource.data.status == 'completed'
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // Delete: mitra bisa menghapus pesanan dari daftar Kelola Pesanan
      allow delete: if request.auth != null;
    }

    // ─── REVIEWS ────────────────────────────────────────────────────
    // reviews/{orderId} — rating & komentar pembeli ke toko, SATU review
    // per pesanan. Sengaja pakai orderId sebagai docId (bukan auto-id)
    // supaya "1 order cuma bisa direview sekali" bisa ditegakkan LANGSUNG
    // oleh security rules: percobaan submit kedua ke docId yang sama
    // dianggap Firestore sebagai `update` (bukan `create` lagi, karena
    // dokumennya udah ada) — dan rule `update` sengaja TIDAK dibuka di
    // bawah, jadi otomatis ditolak tanpa perlu logic tambahan di app.
    match /reviews/{orderId} {
      // Semua yang login boleh baca (ditampilkan di toko-detail & dashboard mitra)
      allow read: if request.auth != null;

      // Cuma pembeli pemilik order itu sendiri yang boleh bikin review-nya,
      // dan cuma kalau order itu memang miliknya, sudah 'completed'/'selesai',
      // dan storeId di review harus sama persis dengan storeId di order asli
      // (supaya rating gak bisa "ditembak" ke toko lain / dipalsukan).
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.userId
                    && request.resource.data.storeId == get(/databases/$(database)/documents/orders/$(orderId)).data.storeId
                    && get(/databases/$(database)/documents/orders/$(orderId)).data.status in ['completed', 'selesai']
                    && request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() <= 500;

      // Review sengaja TIDAK BOLEH diubah/dihapus siapapun (termasuk oleh
      // pemiliknya sendiri) — jaga integritas rating, biar mitra gak bisa
      // maksa pembeli ubah reviewnya, dan pembeli juga gak bisa "cuci"
      // rating jelek berkali-kali. Kalau nanti mau dibuka buat edit,
      // tinggal tambah rule `allow update` dengan syarat serupa `create`
      // ditambah affectedKeys dibatasi ke ['rating', 'comment'].
    }

    // ─── MAGIC BAGS ─────────────────────────────────────────────────
    // magic_bags — dibaca pembeli di mobile, ditulis mitra lewat web
    match /magic_bags/{docId} {
      // Semua user login bisa baca (pembeli perlu lihat daftar magic bag)
      allow read: if request.auth != null;

      // Hanya mitra toko yang boleh create magic bag
      // Pastikan field storeId di dokumen cocok dengan UID mitra yang login
      allow create: if request.auth != null
                    && isMitra(request.auth.uid)
                    && request.auth.uid == request.resource.data.storeId;

      // Mitra pemilik toko boleh update/hapus apapun di magic bag miliknya.
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.storeId;

      // Pembeli (siapapun yang login) boleh update HANYA field `stok`,
      // dipakai saat checkout (mengurangi stok via transaksi). Field lain
      // (harga, nama, dll) tetap terkunci—cuma mitra yang boleh ubah itu.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stok'])
                    && request.resource.data.stok is int
                    && request.resource.data.stok >= 0
                    && request.resource.data.stok <= resource.data.stok;
    }

    // ─── FAVORITES ──────────────────────────────────────────────────
    // favorites — murni domain pembeli, tidak disentuh web admin.
    match /favorites/{docId} {
      // Baca 1 dokumen spesifik by ID (get) — dipakai detail.tsx buat cek
      // "apakah bag ini udah di-favorite-in", DIPANGGIL TIAP KALI buka
      // halaman detail, walau dokumennya belum pernah ada. Kalau pakai
      // resource.data.userId di sini, pas dokumen belum ada resource.data
      // adalah null, dan null.userId bikin rule gagal dievaluasi -> selalu
      // permission-denied walau user yang benar yang akses. Makanya get
      // divalidasi dari docId (format userId_bagId), bukan dari isi dokumen.
      allow get: if request.auth != null
                 && docId.split('_')[0] == request.auth.uid;

      // Baca koleksi/query (list) — query di app HARUS difilter
      // where('userId', '==', uid) milik user yang login. Firestore
      // membuktikan rule ini terpenuhi untuk SEMUA kemungkinan hasil query
      // berdasarkan constraint where(...) di sisi klien, bukan dengan baca
      // request.query (itu cuma punya limit/offset/orderBy, BUKAN nilai
      // where — request.query.userId selalu undefined, makanya versi
      // sebelumnya selalu ditolak).
      allow list: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && docId.split('_')[0] == request.auth.uid;

      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.auth.uid == request.resource.data.userId;

      allow delete: if request.auth != null
                    && docId.split('_')[0] == request.auth.uid;
    }
  }
}
